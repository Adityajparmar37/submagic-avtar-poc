# ── API Keys ────────────────────────────────────────────────

# Google AI Studio (free) — https://aistudio.google.com
GEMINI_API_KEY=

# ElevenLabs (free plan) — https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Tavus — https://tavus.io
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_REPLICA_ID_AVATAR1=
TAVUS_REPLICA_ID_AVATAR2=
TAVUS_REPLICA_ID_AVATAR3=
TAVUS_REPLICA_ID_AVATAR4=

# Groq (free) — https://console.groq.com/keys
GROQ_API_KEY=

# ── Deployment ───────────────────────────────────────────────

# Backend public URL — required for ElevenLabs audio_url → Tavus lip-sync.
# Set to your Railway backend URL (no trailing slash).
# Local dev: npx localtunnel --port 3001  →  https://xxx.loca.lt
SERVER_BASE_URL=

# Frontend (Vercel) — set this as a Vercel env var, NOT in .env
# Points the React app at the Railway backend.
# Example: https://submagic-backend-xxxx.railway.app
VITE_API_URL=
